# Google Gemini API (Get free key at aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# PostgreSQL Database
POSTGRES_DB=ai_mentor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-random-value
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-random-value@localhost:5432/ai_mentor

# Redis
REDIS_URL=redis://localhost:6379

# JWT - GENERATE A REAL SECRET: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET_KEY=change-me-to-a-random-64-byte-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Server Settings
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Feature flags
USE_LLM_CURRICULUM=true

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_db
